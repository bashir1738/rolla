# Copy to .env.local and fill in. Never commit the real .env.local.

# ── Turnkey backend ──────────────────────────────────────────────────────────
# URL of your backend API that wraps Turnkey (Node.js / serverless / etc.)
# Endpoints it must implement:
#   POST /api/auth/social   → verify OAuth token, return { address, userId, sessionToken }
#   POST /api/tx/sign       → sign serialized tx via Turnkey, return { signedTx }
#   POST /api/msg/sign      → sign message via Turnkey, return { signature }
#   GET  /api/auth/me       → verify session token, return { address, userId } | 401
EXPO_PUBLIC_API_URL=http://localhost:3001

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Web client ID from Google Cloud Console (OAuth 2.0 → Web application).
# In Expo Go the redirect is https://auth.expo.io/@your-username/your-slug.
# Add that URI to Authorized redirect URIs in the Google Cloud Console.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Uncomment once you have a dev build (for native Google sign-in performance):
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# ── Chain RPC ────────────────────────────────────────────────────────────────
# Optional: dedicated Sepolia RPC (Infura/Alchemy). Falls back to public node.
EXPO_PUBLIC_SEPOLIA_RPC_URL=
