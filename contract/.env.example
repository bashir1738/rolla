# Copy to .env and fill in. Never commit the real .env.

# Deployer wallet private key (no 0x prefix)
PRIVATE_KEY=

# Infura API key (used when SEPOLIA_RPC_URL is not set)
INFURA_API_KEY=

# Optional: override the Sepolia RPC endpoint
SEPOLIA_RPC_URL=

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=
